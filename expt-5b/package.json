{
  "name": "expt-5b",
  "version": "1.0.0",
  "description": "Experiment 5B - MongoDB integration with Node.js and Express",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server.js",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "client:build:gh": "npm --prefix client run build:gh",
    "client:deploy": "npm --prefix client run deploy",
    "index-test": "node index-test.js"
  },
  "keywords": [
    "mongodb",
    "mongoose",
    "express",
    "full-stack-lab"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mongoose": "^8.8.4",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.7"
  }
}
